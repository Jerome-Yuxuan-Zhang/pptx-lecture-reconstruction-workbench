PPTX2DOCX_OUTPUT_DIR=artifacts
PPTX2DOCX_LOG_LEVEL=INFO
PPTX2DOCX_DEFAULT_BODY_FONT=Times New Roman
PPTX2DOCX_DEFAULT_CJK_FONT=Noto Serif SC
PPTX2DOCX_DEFAULT_FONT_SIZE_PT=12
PPTX2DOCX_DEFAULT_LINE_SPACING=1.0
PPTX2DOCX_EXPORT_NOTES=false
PPTX2DOCX_EXPORT_FOOTER=false
PPTX2DOCX_DIAGRAM_FALLBACK=svg+preview
PPTX2DOCX_ENABLE_LLM=false
PPTX2DOCX_LLM_PROVIDER=openai
PPTX2DOCX_LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
